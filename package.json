{
  "name": "same-origin-speed-test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/browser-app.js --bundle --format=esm --outfile=public/app.js",
    "test": "node --test",
    "dev:local": "npm run build && node dev-server.mjs",
    "dev": "npm run build && npx wrangler dev",
    "deploy": "npm run build && npx wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/speedtest": "^1.10.1",
    "esbuild": "^0.28.0",
    "html-to-image": "^1.11.13"
  }
}
